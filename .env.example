# Required for production — set a strong random secret (e.g. openssl rand -base64 48)
# If not set, a random secret is auto-generated and saved to data/.jwt-secret
JWT_SECRET=

# Port to listen on (default: 3000)
PORT=3000

# Set to 'false' to disable public registration (only existing users can log in)
ALLOW_REGISTRATION=true

# Minimum password length (default: 8)
MIN_PASSWORD_LENGTH=8
